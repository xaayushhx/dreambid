{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "npm install && npm run build"
  },
  "deploy": {
    "startCommand": "npm run start",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5,
    "healthcheck": {
      "enabled": true,
      "interval": 10,
      "timeout": 5,
      "httpPath": "/api/health"
    }
  }
}
